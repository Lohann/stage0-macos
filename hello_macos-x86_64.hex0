## Mach-o Executable File
## Reference:
## https://github.com/apple-oss-distributions/xnu/blob/ac9718fb1af618d5ce8678d0dc6e8a58f252216f/EXTERNAL_HEADERS/mach-o/loader.h#L50-L81
##
## Oficial Git Repo: https://github.com/Lohann/stage0-macos
##
                 # --- Mach-O header ---
CFFAEDFE         # MH_MAGIC_64
0700             # CPU_TYPE_I386
0001             # CPU_ARCH_ABI64
0300             # CPU_SUBTYPE_I386_ALL
0080             # CPU_SUBTYPE_LIB64
02000000         # MH_EXECUTE
03000000         # |- ncmds        = 3
48010000         # |- sizeofcmds   =
01000000         # |- flags        = MH_NOUNDEFS
00000000         # |- reserved

                 # --- Command 1 ---
19000000         # |- cmd          = LC_SEGMENT_64
48000000         # |- size         = 72
5F5F504147455A45 # |- segment name = "__PAGEZERO"
524F000000000000 # |                 (pad to 16 bytes)
0000000000000000 # |- vmaddr       = 0
0000000001000000 # |- vmsize       = 16777216 (4GB)
0000000000000000 # |- fileoff      = 0
0000000000000000 # |- filesize     = 0
00000000         # |- maxprot      = 0
00000000         # |- initprot     = 0
00000000         # |- nsects       = 0
00000000         # |- flags        = 0

                 # --- Command 2 ---
19000000         # |- cmd          = LC_SEGMENT_64
48000000         # |- size         = 72
5F5F544558540000 # |- segment name = "__TEXT"
0000000000000000 # |                 (pad to 16 bytes)
0000000001000000 # |- vmaddr       = 16777216 (4GB)
B501000000000000 # |- vmsize       = 437
0000000000000000 # |- fileoff      = 0
B501000000000000 # |- filesize     = 437
07000000         # |- maxprot  = VM_PROT_READ | VM_PROT_WRITE | VM_PROT_EXECUTE
05000000         # |- initprot = VM_PROT_READ | VM_PROT_EXECUTE
00000000         # |- nsects
00000000         # |- flags

                 # --- Command 3 ---
05000000         # |- cmd     = LC_UNIXTHREAD
B8000000         # |- cmdsize = 184
04000000         # |- flavor  = x86_THREAD_STATE64
2A000000         # |- count   = 42
0000000000000000 # |- rax     = 0
0000000000000000 # |- rbx     = 0
0000000000000000 # |- rcx     = 0
0000000000000000 # |- rdx     = 0
0000000000000000 # |- rdi     = 0
0000000000000000 # |- rsi     = 0
0000000000000000 # |- rbp     = 0
0000000000000000 # |- rsp     = 0
0000000000000000 # |- r8      = 0
0000000000000000 # |- r9      = 0
0000000000000000 # |- r10     = 0
0000000000000000 # |- r11     = 0
0000000000000000 # |- r12     = 0
0000000000000000 # |- r13     = 0
0000000000000000 # |- r14     = 0
0000000000000000 # |- r15     = 0
6801000001000000 # |- rip     = ___codestart = 0x0100000168
0000000000000000 # |- rflags  = 0
0000000000000000 # |- cs      = 0
0000000000000000 # |- fs      = 0
0000000000000000 # |- gs      = 0

# ___codestart (address 0x0100000168)
# https://github.com/apple-oss-distributions/dyld/blob/fd8d0c4d52320ebf64db34f3cb280310d905c5ae/dyld/dyldStartup.s#L80-L84
4889E7           # mov     rdi, rsp         ; save pointer to KernelArgs
4883E4F0         # and     rsp, -16         ; force SSE alignment
BD00000000       # mov     ebp, 0x0         ; terminate frame pointer chain
6A00             # push    0x0              ; simulate a call with a return address of zero

# exec: printf("hello world\n")
BF01000000       # mov     edi, 0x1         ; ARG1 = STDOUT
48BEA501000001   # movabs  rsi, 0x1000001a5 ; ARG2 = :hello_str (string memory address)
000000           #
BA0C000000       # mov     edx, 0xc         ; ARG3 = 12         (string length)
B804000002       # mov     eax, 0x2000004   ; SYSCALL      = SYS_write
0F05             # syscall

# exec: exit(0)
BF00000000       # mov     edi, 0x0         ; ARG1 = 0 (status code)
B801000002       # mov     eax, 0x2000001   ; SYSCALL      = SYS_exit
0F05             # syscall

# (pad to 16 bytes)
0000000000000000           

# hello_str: (address 0x1000001a5)
68656C6C6F20776F726C640A000000 # "hello world\n\0\0\0"

# # Fill the rest of the file with zeros (Mach-O files must be at least 4096 bytes)
